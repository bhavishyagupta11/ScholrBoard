PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/scholrboard
MONGODB_URI_TEST=mongodb://localhost:27017/scholrboard_test
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
PUBLIC_API_URL=http://localhost:5000/api
REQUEST_LOG_LEVEL=verbose

# Optional — only if using Cloudinary uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional — only if AI routes are enabled
# GEMINI_API_KEY=

# V2: Email Service (Nodemailer) — required for contact form + ticket email notifications
# Use Gmail App Password (not your account password). Leave blank to disable emails.
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_gmail_app_password
# ADMIN_CONTACT_EMAIL=admin@yourdomain.com
